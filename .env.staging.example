# Template for the STAGING server's .env file.
# On the Hostinger server, copy this to `.env` next to wp-config.php
# and fill in the values. Git ignores all .env files.

WORDPRESS_DB_NAME=u722617394_pethoven
WORDPRESS_DB_USER=u722617394_pethoven
WORDPRESS_DB_PASSWORD=REPLACE_WITH_STAGING_DB_PASSWORD
WORDPRESS_DB_HOST=localhost
WORDPRESS_TABLE_PREFIX=wp_

WP_HOME=https://seashell-opossum-486356.hostingersite.com
WP_SITEURL=https://seashell-opossum-486356.hostingersite.com

WP_ENVIRONMENT_TYPE=staging
WP_DEBUG=false
WP_CACHE=true
DISABLE_WP_CRON=false
SCRIPT_DEBUG=false
CONCATENATE_SCRIPTS=true
COMPRESS_CSS=true
COMPRESS_SCRIPTS=true
FORCE_SSL_ADMIN=true

WP_MEMORY_LIMIT=512M
WP_MAX_MEMORY_LIMIT=512M
