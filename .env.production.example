# Template for the PRODUCTION server's .env file.
# On the Hostinger server (pethoven.com), copy this to `.env` next to
# wp-config.php and fill in the values. Git ignores all .env files.
#
# Get DB credentials from Hostinger hPanel → Websites → pethoven.com
# → Databases → Management (user / password / DB name).

WORDPRESS_DB_NAME=REPLACE_WITH_PROD_DB_NAME
WORDPRESS_DB_USER=REPLACE_WITH_PROD_DB_USER
WORDPRESS_DB_PASSWORD=REPLACE_WITH_PROD_DB_PASSWORD
WORDPRESS_DB_HOST=localhost
WORDPRESS_TABLE_PREFIX=wp_

WP_HOME=https://pethoven.com
WP_SITEURL=https://pethoven.com

WP_ENVIRONMENT_TYPE=production
WP_DEBUG=false
WP_CACHE=true
DISABLE_WP_CRON=false
SCRIPT_DEBUG=false
CONCATENATE_SCRIPTS=true
COMPRESS_CSS=true
COMPRESS_SCRIPTS=true
FORCE_SSL_ADMIN=true

WP_MEMORY_LIMIT=512M
WP_MAX_MEMORY_LIMIT=512M
